{{/* macOS-only setup: laptop vs desktop from the hardware model. */}}
{{- $device_type := "desktop" -}}
{{- if contains "MacBook" (output "sysctl" "-n" "hw.model") -}}
{{-   $device_type = "laptop" -}}
{{- end -}}

{{/* promptStringOnce keeps the stored value as the default on re-init. */}}
{{- $email := promptStringOnce . "email" "Email address" -}}

[data]
  email = {{ $email | quote }}
  device_type = {{ $device_type | quote }}
